# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite:///./agrosight.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/agrosight

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=false

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Email (OTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your@gmail.com

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_PATH=ml/saved_models/resnet_plant_disease.pth
CLASS_NAMES_PATH=ml/saved_models/class_names.json
CONFIDENCE_THRESHOLD=0.7

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
POSTGRES_USER=agrosight
POSTGRES_PASSWORD=agrosight_pass
POSTGRES_DB=agrosight
