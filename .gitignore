# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.Python
venv/
env/
ENV/
.pytest_cache/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite3
*.db-journal

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
*.local

# ── ML Data & Models ──────────────────────────────────────────────────────────
backend/ml/data/raw/
backend/ml/data/processed/
