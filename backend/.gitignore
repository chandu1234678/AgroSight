# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
*.egg-info/
.Python
venv/
env/
ENV/
.pytest_cache/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite3
*.db-journal
agrosight.db

# ── ML Models & Data ──────────────────────────────────────────────────────────
ml/data/raw/
ml/data/processed/
